#include <stdio.h>

int main() {
    int num, i;

    // Prompt the user for input
    printf("Enter a positive integer: ");
    scanf("%d", &num);

    printf("Factors of %d are: ", num);

    // Loop from 1 to the number itself
    for (i = 1; i <= num; ++i) {
        // Check if the current number (i) divides the input number (num) evenly
        if (num % i == 0) {
            printf("%d ", i);
        }
    }

    return 0;
}
