#include <stdio.h>
#include <math.h>

int main() {
    int i, sum, temp, remainder, n;

    printf("Armstrong numbers between 1 and 100:\n");

    for (i = 1; i <= 100; i++) {
        temp = i;
        sum = 0;
        
        // Find the number of digits (n)
        if (i < 10) n = 1;
        else if (i < 100) n = 2;
        else n = 3;

        // Calculate sum of digits raised to power n
        while (temp > 0) {
            remainder = temp % 10;
            sum = sum + pow(remainder, n);
            temp = temp / 10;
        }

        // If sum equals the original number, it's an Armstrong number
        if (sum == i) {
            printf("%d ", i);
        }
    }

    return 0;
