#include <stdio.h>

int main() {
    int arr[] = {25, 18, 35, 3, 77, 21};
    int n = sizeof(arr) / sizeof(arr[0]);
    int temp;

    // Sorting in ascending order
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] > arr[j]) {
                // Swap elements
                temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }

    printf("Sorted Array: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    return 0;
}
