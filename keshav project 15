#include <stdio.h>

int main() {
    int rows = 6;
    int i, j, space;
    int coef;

    for(i = 0; i < rows; i++) {

        // Print spaces
        for(space = 1; space <= rows - i; space++) {
            printf("  ");
        }

        coef = 1;
        for(j = 0; j <= i; j++) {
            printf("%4d", coef);
            coef = coef * (i - j) / (j + 1);
        }

        printf("\n");
    }

    return 0;
}
