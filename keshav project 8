#include <stdio.h>

int main() {
    int month;
    
    printf("Enter month number (1-12): ");
    scanf("%d", &month);
    
    switch(month) {
        case 1:
        case 3:
        case 5:
        case 7:
        case 8:
        case 10:
        case 12:
            printf("%d has 31 days\n", month);
            break;
        case 4:
        case 6:
        case 9:
        case 11:
            printf("%d has 30 days\n", month);
            break;
        case 2:
            printf("February has 28 days\n");
            break;
        default:
            printf("Invalid month number\n");
    }
    
    return 0;
}
