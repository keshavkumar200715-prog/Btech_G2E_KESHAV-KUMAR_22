#include <stdio.h>
#define SIZE 5

int main() {
    int original_arr[SIZE] = {1, 2, 3, 4, 5};
    int reversed_arr[SIZE];
    int i;

    // Copy elements in reverse order
    for (i = 0; i < SIZE; i++) {
        reversed_arr[i] = original_arr[SIZE - 1 - i];
    }

    // Print the original array
    printf("Original array: ");
    for (i = 0; i < SIZE; i++) {
        printf("%d ", original_arr[i]);
    }
    
    // Print the reversed array
    printf("\nReversed array: ");
    for (i = 0; i < SIZE; i++) {
        printf("%d ", reversed_arr[i]);
    }

    return 0;
}
