#include <stdio.h>

int main() {
    int n, i;
    int source[100], destination[100];

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements of the array:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &source[i]);
    }

    // Copying elements
    for(i = 0; i < n; i++) {
        destination[i] = source[i];
    }

    printf("Elements of the new array are:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", destination[i]);
    }

    return 0;
}
